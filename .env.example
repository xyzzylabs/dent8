# Matches compose.yml (POSTGRES_PASSWORD=dent8, POSTGRES_DB=dent8; default user `postgres`).
# dent8 reads DENT8_DATABASE_URL; set it from this for a `--features postgres` build.
DENT8_DATABASE_URL=postgres://postgres:dent8@localhost:5432/dent8
DATABASE_URL=postgres://postgres:dent8@localhost:5432/dent8

