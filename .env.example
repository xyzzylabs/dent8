# Matches compose.yml (POSTGRES_PASSWORD=dent8, POSTGRES_DB=dent8; default user `postgres`).
# dent8 reads DENT8_STORE_URL (dispatched by scheme); set it for a `--features postgres` build.
DENT8_STORE_URL=postgres://postgres:dent8@localhost:5432/dent8
# Back-compat alias. Leave it commented: DENT8_STORE_URL takes precedence when both are set,
# so an uncommented alias here would silently shadow edits you make to it. Uncomment only if
# you prefer the old name AND leave DENT8_STORE_URL unset.
# DENT8_DATABASE_URL=postgres://postgres:dent8@localhost:5432/dent8
# Read only by the adapter's own integration tests (cargo test -p dent8-store-postgres):
DATABASE_URL=postgres://postgres:dent8@localhost:5432/dent8

